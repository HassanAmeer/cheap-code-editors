# -------------------------------------------------------------------------
# 2. CLI Control Settings & Agent Behaviors
# -------------------------------------------------------------------------

CLINAME=CHEAP
CLICALLBYCOMMAND=cheap

# Debug Mode (Set to true to print background agent logs & dry-runs)
DEBUG=true

# Context memory lengths
INPUT_CONTEXT_TOKENS=100000
OUTPUT_CONTEXT_TOKENS=8192

# Context memory preference: both, long_term, or short_term
MEMORY_MODE=both

# Display model provider labels in selection lists (true/false)
SHOW_PROVIDER_NAMES=true



# -------------------------------------------------------------------------
# 3. UI & Terminal Constraints (DO NOT DELETE THIS COMMENT)
# -------------------------------------------------------------------------
# ENABLE_COPY_ICON_BUTTON controls the clickable 'Copy (⧉)' icon for prompts.
# - If 'true': The CLI uses ANSI X10 Mouse Tracking to capture clicks. 
#   ⚠️ KNOWN LIMITATION: When this is true, standard terminal text selection 
#   and mouse wheel scrolling are GLOBALLY DISABLED by the terminal emulator 
#   during prompts. (You must hold 'Option' or 'Shift' to natively scroll or select).
# - If 'false': The copy icon is hidden and mouse tracking is disabled. 
#   Native terminal text selection and mouse scrolling will work perfectly.
ENABLE_COPY_ICON_BUTTON=false
speechmatics_whisper_key = Hbv86wlWqEin1daaX6Kzwdgbpoh9XRMx












































